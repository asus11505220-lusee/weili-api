@echo off
chcp 65001 >nul
cd /d "%~dp0"
color 0A

echo ===================================================
echo   🚀 GitHub 全檔案一鍵上傳同步系統 (手動版) 🚀
echo ===================================================
echo.
echo 正在掃描資料夾內的所有變動 (包含 CSV, Python程式, bat檔等)...
echo.

:: 關鍵指令：git add -A 代表掃描資料夾內「所有」新增、修改、刪除的檔案
git add -A

echo 📦 正在將所有檔案打包...
git commit -m "🤖 手動全端同步：更新所有檔案與程式腳本"

echo.
echo ☁️ 正在推送至 GitHub 雲端，請稍候...
git push

echo.
echo ===================================================
echo   🎉 恭喜！資料夾內的所有檔案與程式已全數完美同步！
echo ===================================================
pause